# ChatBI Configuration

# Server Settings
NANOBOT_HOST=0.0.0.0
NANOBOT_PORT=8000
NANOBOT_DEBUG=false

# LLM Settings
NANOBOT_LLM_MODEL=gpt-4
NANOBOT_LLM_API_KEY=your-openai-api-key-here
NANOBOT_LLM_BASE_URL=

# Session Settings
NANOBOT_SESSION_STORAGE_PATH=./workspace/sessions
NANOBOT_SESSION_TIMEOUT=3600

# Database Connections (for MySQL/Hive skills)
NANOBOT_SQL_ENABLED=true
NANOBOT_SQL_CONNECTIONS_MAIN=mysql://user:password@localhost:3306/database
NANOBOT_SQL_CONNECTIONS_ANALYTICS=mysql://user:password@localhost:3306/analytics

# RAG Settings (for knowledge/search skills)
NANOBOT_RAG_ENABLED=true
NANOBOT_RAG_EMBEDDING_MODEL=text-embedding-3-small
NANOBOT_RAG_VECTOR_DB=chromadb

# Time Series Settings
NANOBOT_TS_ENABLED=true
NANOBOT_TS_DEFAULT_MODEL=prophet

# API Settings
NANOBOT_API_KEY=
NANOBOT_CORS_ORIGINS=*
