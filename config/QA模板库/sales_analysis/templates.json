{
  "templates": [
    {
      "id": "sales_trend_daily",
      "name": "日销售趋势",
      "category": "销售趋势",
      "description": "查看指定时间范围内的每日销售额变化趋势",
      "question_template": "查询{{time_range}}的每日销售额趋势",
      "pattern_id": "trend_analysis",
      "default_params": {
        "metric": "actual_amount",
        "time_grain": "DAY",
        "time_range": {
          "start": "2024-01-01",
          "end": "2024-01-31"
        }
      },
      "params_schema": {
        "time_range": {
          "label": "时间范围",
          "type": "date_range",
          "required": true,
          "default": "last_30_days"
        },
        "metric": {
          "label": "指标",
          "type": "select",
          "options": [
            {"value": "actual_amount", "label": "销售额"},
            {"value": "order_count", "label": "订单量"},
            {"value": "quantity", "label": "商品数量"}
          ],
          "default": "actual_amount"
        },
        "time_grain": {
          "label": "时间粒度",
          "type": "select",
          "options": [
            {"value": "DAY", "label": "日"},
            {"value": "WEEK", "label": "周"},
            {"value": "MONTH", "label": "月"}
          ],
          "default": "DAY"
        }
      },
      "examples": [
        "查询最近30天的每日销售额趋势",
        "查看今年1月份的销售订单量趋势",
        "显示上个季度的商品销售趋势"
      ]
    },
    {
      "id": "sales_yoy_mom",
      "name": "销售同环比分析",
      "category": "销售趋势",
      "description": "对比当前销售额与去年同期和上期的变化",
      "question_template": "{{time_period}}的销售额同环比分析",
      "pattern_id": "yoy_mom",
      "default_params": {
        "metric": "actual_amount",
        "time_grain": "MONTH",
        "time_range": {
          "start": "2024-01-01",
          "end": "2024-03-31"
        },
        "comparison_types": ["yoy", "mom"]
      },
      "params_schema": {
        "metric": {
          "label": "指标",
          "type": "select",
          "options": [
            {"value": "actual_amount", "label": "销售额"},
            {"value": "order_count", "label": "订单量"}
          ],
          "default": "actual_amount"
        },
        "time_grain": {
          "label": "时间粒度",
          "type": "select",
          "options": [
            {"value": "DAY", "label": "日"},
            {"value": "WEEK", "label": "周"},
            {"value": "MONTH", "label": "月"}
          ],
          "default": "MONTH"
        },
        "time_range": {
          "label": "时间范围",
          "type": "date_range",
          "required": true,
          "default": "last_6_months"
        },
        "comparison_types": {
          "label": "对比类型",
          "type": "multi_select",
          "options": [
            {"value": "yoy", "label": "同比"},
            {"value": "mom", "label": "环比"}
          ],
          "default": ["yoy", "mom"]
        }
      },
      "examples": [
        "今年第一季度销售额的同比增长率是多少",
        "本月销售额与上月相比变化如何",
        "最近6个月的销售额同环比情况"
      ]
    },
    {
      "id": "top_products",
      "name": "TopN产品销售",
      "category": "产品分析",
      "description": "查询销售额排名TopN的产品",
      "question_template": "查询{{time_point}}销售额Top{{n}}的产品",
      "pattern_id": "topn",
      "default_params": {
        "metric": "actual_amount",
        "dimension": "product_name",
        "n": 10,
        "time_point": "2024-01",
        "include_others": true
      },
      "params_schema": {
        "time_point": {
          "label": "时间点",
          "type": "date",
          "required": true,
          "default": "current_month"
        },
        "metric": {
          "label": "指标",
          "type": "select",
          "options": [
            {"value": "actual_amount", "label": "销售额"},
            {"value": "quantity", "label": "销售量"},
            {"value": "order_count", "label": "订单量"}
          ],
          "default": "actual_amount"
        },
        "n": {
          "label": "Top N",
          "type": "number",
          "min": 1,
          "max": 100,
          "default": 10
        },
        "include_others": {
          "label": "包含其他",
          "type": "boolean",
          "default": true
        }
      },
      "examples": [
        "本月销售额Top10的产品有哪些",
        "查询2023年销售量Top20的产品",
        "上个季度订单最多的5个产品"
      ]
    },
    {
      "id": "category_breakdown",
      "name": "产品类别销售分布",
      "category": "产品分析",
      "description": "按产品类别分组查看销售数据分布",
      "question_template": "{{time_point}}各类别的{{metric}}分布",
      "pattern_id": "agg_query",
      "default_params": {
        "dimensions": ["category_name"],
        "metric": "actual_amount",
        "time_point": "2024-01",
        "filters": []
      },
      "params_schema": {
        "time_point": {
          "label": "时间点",
          "type": "date",
          "required": true,
          "default": "current_month"
        },
        "metric": {
          "label": "指标",
          "type": "select",
          "options": [
            {"value": "actual_amount", "label": "销售额"},
            {"value": "quantity", "label": "销售量"},
            {"value": "order_count", "label": "订单量"}
          ],
          "default": "actual_amount"
        },
        "dimensions": {
          "label": "维度",
          "type": "multi_select",
          "options": [
            {"value": "category_name", "label": "产品类别"},
            {"value": "brand", "label": "品牌"},
            {"value": "channel_name", "label": "渠道"}
          ],
          "default": ["category_name"]
        }
      },
      "examples": [
        "本月各类别的销售额分布如何",
        "查看各品牌的销售数量占比",
        "不同渠道的订单数量分布"
      ]
    },
    {
      "id": "channel_comparison",
      "name": "渠道销售对比",
      "category": "渠道分析",
      "description": "对比不同销售渠道的业绩表现",
      "question_template": "对比{{time_point}}各渠道的{{metric}}",
      "pattern_id": "comparison",
      "default_params": {
        "metric": "actual_amount",
        "dimension": "channel_name",
        "comparison_field": "channel_type",
        "comparison_values": ["online", "offline"],
        "time_point": "2024-01"
      },
      "params_schema": {
        "time_point": {
          "label": "时间点",
          "type": "date",
          "required": true,
          "default": "current_month"
        },
        "metric": {
          "label": "指标",
          "type": "select",
          "options": [
            {"value": "actual_amount", "label": "销售额"},
            {"value": "order_count", "label": "订单量"}
          ],
          "default": "actual_amount"
        },
        "comparison_values": {
          "label": "对比渠道",
          "type": "multi_select",
          "options": [
            {"value": "online", "label": "线上"},
            {"value": "offline", "label": "线下"},
            {"value": "direct", "label": "直营"},
            {"value": "third_party", "label": "第三方"}
          ],
          "default": ["online", "offline"]
        }
      },
      "examples": [
        "对比线上和线下渠道的销售额",
        "各平台的订单量对比",
        "直营和第三方渠道的业绩对比"
      ]
    },
    {
      "id": "customer_type_analysis",
      "name": "客户类型分析",
      "category": "客户分析",
      "description": "分析不同类型客户（新客/老客/VIP）的消费行为",
      "question_template": "分析{{time_range}}不同客户类型的{{metric}}",
      "pattern_id": "agg_query",
      "default_params": {
        "dimensions": ["customer_type"],
        "metric": "actual_amount",
        "time_range": {
          "start": "2024-01-01",
          "end": "2024-01-31"
        },
        "filters": []
      },
      "params_schema": {
        "time_range": {
          "label": "时间范围",
          "type": "date_range",
          "required": true,
          "default": "last_30_days"
        },
        "metric": {
          "label": "指标",
          "type": "select",
          "options": [
            {"value": "actual_amount", "label": "销售额"},
            {"value": "order_count", "label": "订单量"},
            {"value": "customer_count", "label": "客户数"}
          ],
          "default": "actual_amount"
        }
      },
      "examples": [
        "分析新客和老客的销售额对比",
        "查看VIP客户的消费占比",
        "不同客户类型的订单量分布"
      ]
    },
    {
      "id": "repurchase_rate",
      "name": "复购率分析",
      "category": "客户分析",
      "description": "计算指定时间范围内的客户复购率",
      "question_template": "{{time_period}}的客户复购率是多少",
      "pattern_id": "point_query",
      "default_params": {
        "metric": "repurchase_rate",
        "time_point": "2024-01"
      },
      "params_schema": {
        "time_point": {
          "label": "时间点",
          "type": "date",
          "required": true,
          "default": "current_month"
        }
      },
      "examples": [
        "本月客户复购率是多少",
        "上季度复购率如何",
        "今年复购率变化趋势"
      ]
    },
    {
      "id": "regional_sales",
      "name": "地区销售分析",
      "category": "区域分析",
      "description": "按地区维度分析销售数据分布",
      "question_template": "分析{{time_point}}各地区{{metric}}",
      "pattern_id": "agg_query",
      "default_params": {
        "dimensions": ["province"],
        "metric": "actual_amount",
        "time_point": "2024-01",
        "filters": []
      },
      "params_schema": {
        "time_point": {
          "label": "时间点",
          "type": "date",
          "required": true,
          "default": "current_month"
        },
        "metric": {
          "label": "指标",
          "type": "select",
          "options": [
            {"value": "actual_amount", "label": "销售额"},
            {"value": "order_count", "label": "订单量"},
            {"value": "customer_count", "label": "客户数"}
          ],
          "default": "actual_amount"
        },
        "dimensions": {
          "label": "地区维度",
          "type": "multi_select",
          "options": [
            {"value": "province", "label": "省份"},
            {"value": "city", "label": "城市"}
          ],
          "default": ["province"]
        }
      },
      "examples": [
        "本月各省市的销售额分布",
        "查看不同城市的订单量对比",
        "各地区的客户数量分析"
      ]
    }
  ],
  "categories": {
    "销售趋势": {
      "templates": ["sales_trend_daily", "sales_yoy_mom"],
      "icon": "📈",
      "description": "分析销售数据的时间趋势和变化"
    },
    "产品分析": {
      "templates": ["top_products", "category_breakdown"],
      "icon": "📦",
      "description": "了解产品和类别的销售表现"
    },
    "渠道分析": {
      "templates": ["channel_comparison"],
      "icon": "🛒",
      "description": "对比不同销售渠道的业绩"
    },
    "客户分析": {
      "templates": ["customer_type_analysis", "repurchase_rate"],
      "icon": "👥",
      "description": "分析客户群体的消费行为"
    },
    "区域分析": {
      "templates": ["regional_sales"],
      "icon": "🗺️",
      "description": "了解不同地区的销售分布"
    }
  }
}
