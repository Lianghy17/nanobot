      "enabled": true,
      "description": "搜索知识库获取相关信息"
    },
    "execute_sql": {
      "enabled": true,
      "description": "执行SQL查询数据库"
    },
    "execute_python": {
      "enabled": true,
      "description": "执行Python代码进行数据分析"
    },
    "read_file": {
      "enabled": true,
      "description": "读取文件内容"
