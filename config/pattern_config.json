{
  "patterns": {
    "point_query": {
      "id": "point_query",
      "name": "点查",
      "description": "单时间点单指标查询",
      "category": "basic",
      "complexity": 1,
      "time_mode": "SINGLE_POINT",
      "space_mode": "NONE",
      "sql_template": "SELECT {metric} as value FROM {table} WHERE {time_filter}",
      "features": [],
      "required_tables": ["fact"],
      "optional_features": [],
      "params_schema": {
        "metric": {"type": "string", "required": true, "description": "要查询的指标字段，如：total_amount, quantity"},
        "time_point": {"type": "string", "required": true, "description": "查询的时间点，如：今天、昨天、2024-01-01"}
      },
      "user_prompt": "查询单个时间点的指标值，适合快速获取某个时间点的数据快照。",
      "important_notes": ["指标和时间点是必填参数，如：销售额、今天/昨天/2024-03-01", "时间点支持相对时间(今天/昨天/本周/本月)和绝对时间(2024-01-01)", "指标会自动求和聚合"],
      "examples": ["查询今天的销售额，指标是销售额", "查询昨天的订单量，指标是订单数量"]
    },

    "detail_query": {
      "id": "detail_query",
      "name": "明细查询",
      "description": "查询详细记录列表",
      "category": "basic",
      "complexity": 1,
      "time_mode": "RANGE",
      "space_mode": "NONE",
      "sql_template": "SELECT {fields} FROM {table} WHERE {time_filter} {filters} LIMIT {limit}",
      "features": ["sensitive_mask", "stream_return", "limit_control"],
      "required_tables": ["fact"],
      "optional_features": ["dimension_join"],
      "params_schema": {
        "fields": {"type": "array", "required": true, "description": "要返回的字段列表，如：[order_id, customer_name, amount]"},
        "filters": {"type": "array", "default": [], "description": "过滤条件列表"},
        "limit": {"type": "integer", "default": 100, "max": 10000, "description": "返回记录数量限制"}
      },
      "security_rules": {
        "max_rows": 10000,
        "sensitive_fields": ["phone", "id_card", "address"]
      },
      "user_prompt": "查询符合条件的详细数据记录，可指定返回字段、筛选条件和返回数量。",
      "important_notes": ["字段列表是必填参数，如：[订单ID, 客户姓名, 金额]", "敏感字段(手机号、身份证等)会自动脱敏", "默认返回100条，最多10000条"],
      "examples": ["查询最近一周的订单明细，字段是[订单ID, 客户姓名, 金额]", "查看金额大于1000元的订单，字段是[订单ID, 金额]"]
    },

    "agg_query": {
      "id": "agg_query",
      "name": "聚合查询",
      "description": "按维度分组聚合",
      "category": "basic",
      "complexity": 1,
      "time_mode": "SINGLE_POINT",
      "space_mode": "SINGLE",
      "sql_template": "SELECT {dimensions}, {metric} as value FROM {table} WHERE {time_filter} {filters} GROUP BY {dimensions} ORDER BY value DESC",
      "features": [],
      "required_tables": ["fact"],
      "optional_features": ["having_clause", "rollup_subtotal"],
      "params_schema": {
        "dimensions": {"type": "array", "required": true, "max_items": 3, "description": "分组维度，如：[category, region]"},
        "metric": {"type": "string", "required": true, "description": "聚合指标，如：total_amount"},
        "filters": {"type": "array", "default": [], "description": "过滤条件"}
      },
      "user_prompt": "按一个或多个维度对指标进行分组汇总，适合做数据透视分析。",
      "important_notes": ["维度和指标是必填参数，维度如：[产品分类]、指标如：销售额", "最多支持3个维度进行分组，维度间用'和'或'、'连接", "结果按指标值降序排列"],
      "examples": ["按商品分类统计本月的销售额，维度是[商品分类]，指标是销售额", "按地区和渠道统计今年的订单量，维度是[地区, 渠道]，指标是订单数量"]
    },

    "trend_analysis": {
      "id": "trend_analysis",
      "name": "趋势分析",
      "description": "指标随时间变化趋势",
      "category": "time_series",
      "complexity": 2,
      "time_mode": "SERIES",
      "space_mode": "SINGLE",
      "sql_template": "SELECT {time_trunc} as period, SUM({metric}) as value FROM {table} WHERE {time_filter} {filters} GROUP BY {time_trunc} ORDER BY period",
      "features": ["date_fill", "granularity_auto"],
      "required_tables": ["fact", "dim_date"],
      "optional_features": ["forecast_line", "anomaly_overlay"],
      "params_schema": {
        "metric": {"type": "string", "required": true, "description": "分析的趋势指标，如：sales_amount"},
        "time_grain": {"type": "enum", "options": ["DAY", "WEEK", "MONTH"], "default": "DAY", "description": "时间粒度：日/周/月"},
        "time_range": {"type": "range", "required": true, "max_days": 365, "description": "分析的时间范围"},
        "dimension": {"type": "string", "default": null, "description": "可选的分维度分析"}
      },
      "grain_mapping": {
        "DAY": "DATE({time_field})",
        "WEEK": "DATE_TRUNC('week', {time_field})",
        "MONTH": "DATE_TRUNC('month', {time_field})"
      },
      "user_prompt": "分析指标随时间的变化趋势，按日/周/月粒度查看数据走势。",
      "important_notes": ["时间范围是必填参数，如：最近30天、从2024-01-01到2024-03-31", "时间粒度可选：日、周、月（超过90天建议用周或月）", "可添加维度参数进行分维度趋势对比"],
      "examples": ["分析最近30天的销售趋势，时间粒度为日", "查看过去半年每月的订单量变化，时间范围是今年"]
    },

    "yoy_mom": {
      "id": "yoy_mom",
      "name": "同环比分析",
      "description": "同比和环比对比分析",
      "category": "time_series",
      "complexity": 3,
      "time_mode": "OFFSET",
      "space_mode": "NONE",
      "sql_template": "SELECT {time_trunc} as period, SUM({metric}) as current_value, LAG(SUM({metric}), 1) OVER (ORDER BY {time_trunc}) as mom_value, LAG(SUM({metric}), 12) OVER (ORDER BY {time_trunc}) as yoy_value FROM {table} WHERE {time_filter} GROUP BY {time_trunc} ORDER BY period",
      "features": ["self_join", "ratio_calc", "multi_period_union"],
      "required_tables": ["fact"],
      "optional_features": ["ytd_comparison", "qtd_comparison"],
      "params_schema": {
        "metric": {"type": "string", "required": true, "description": "要对比的指标，如：revenue"},
        "time_grain": {"type": "enum", "options": ["DAY", "WEEK", "MONTH"], "default": "DAY", "description": "时间粒度"},
        "time_range": {"type": "range", "required": true, "description": "分析的时间范围"},
        "comparison_types": {"type": "array", "options": ["yoy", "mom"], "default": ["yoy", "mom"], "description": "对比类型：同比(yoy)或环比(mom)"}
      },
      "offset_strategies": {
        "yoy": {"type": "year", "shift": "INTERVAL 1 YEAR", "alternative": "52 WEEK"},
        "mom": {"type": "month", "shift": "INTERVAL 1 MONTH", "alternative": "4 WEEK"}
      },
      "user_prompt": "对比分析指标的同比(与去年同期)和环比(与上一周期)变化，发现增长或下降趋势。",
      "important_notes": ["时间范围是必填参数，如：最近12个月、从2024-01-01到2024-12-31", "时间粒度可选：日、周、月（建议以月为粒度进行同比分析）", "对比类型可选：同比、环比或两者同时分析"],
      "examples": ["分析本月销售额的同比环比情况，时间范围是今年", "查看最近12个月各月的同比增长率"]
    },

    "cumulative": {
      "id": "cumulative",
      "name": "累积分析",
      "description": "累计值计算",
      "category": "time_series",
      "complexity": 2,
      "time_mode": "SERIES",
      "space_mode": "NONE",
      "sql_template": "SELECT {time_trunc} as period, SUM({metric}) as period_value, SUM(SUM({metric})) OVER (ORDER BY {time_trunc}) as cumulative_value FROM {table} WHERE {time_filter} GROUP BY {time_trunc} ORDER BY period",
      "features": ["window_function", "running_total"],
      "required_tables": ["fact"],
      "optional_features": ["target_line", "achievement_rate"],
      "params_schema": {
        "metric": {"type": "string", "required": true, "description": "要累计的指标，如：sales_amount"},
        "time_grain": {"type": "enum", "options": ["DAY", "WEEK", "MONTH"], "default": "DAY", "description": "时间粒度"},
        "time_range": {"type": "range", "required": true, "description": "累计的时间范围"}
      },
      "table_preferences": ["agg_table", "full_snapshot", "inc_event"],
      "performance_notes": "增量表大时间范围性能较差，建议用预计算表",
      "user_prompt": "计算指标的累计值，用于追踪目标完成进度，展示每个时间点的当期值和累计值。",
      "important_notes": ["时间范围是必填参数，如：最近30天、从2024-01-01到2024-12-31", "时间粒度可选：日、周、月", "适合用于追踪年度目标、月度目标的完成率"],
      "examples": ["分析今年以来销售额的累计趋势，时间范围是今年，粒度为月", "查看本月每日订单的累计量"]
    },

    "breakdown": {
      "id": "breakdown",
      "name": "维度拆解",
      "description": "多维度交叉分析",
      "category": "dimensional",
      "complexity": 2,
      "time_mode": "SINGLE_POINT",
      "space_mode": "MULTI",
      "sql_template": "SELECT {dimensions}, {metric} as value FROM {table} WHERE {time_filter} {filters} GROUP BY {dimensions} {rollup_clause} ORDER BY value DESC",
      "features": ["multi_groupby", "subtotal", "rollup", "drill_path"],
      "required_tables": ["fact"],
      "optional_features": ["pivot_output", "percentage_of_total"],
      "params_schema": {
        "metric": {"type": "string", "required": true, "description": "要分析的指标"},
        "dimensions": {"type": "array", "required": true, "min_items": 1, "max_items": 3, "description": "拆解的维度列表，如：[category, region]"},
        "include_subtotal": {"type": "boolean", "default": false, "description": "是否包含小计"},
        "time_point": {"type": "string", "required": true, "description": "分析的时间点"}
      },
      "limits": {"max_dimensions": 3, "max_combinations": 10000},
      "user_prompt": "从多个维度交叉拆解分析指标，找出贡献最大的维度组合，支持多维数据透视。",
      "important_notes": ["时间点是必填参数，如：本月、昨天、2024-03-01", "支持1-3个维度的交叉分析，维度间用'和'或'、'连接", "可开启小计查看各维度的汇总情况"],
      "examples": ["分析本月各分类各地区的销售额分布", "查看今年不同品牌和不同渠道的销售对比"]
    },

    "topn": {
      "id": "topn",
      "name": "TopN排名",
      "description": "排名分析",
      "category": "dimensional",
      "complexity": 2,
      "time_mode": "SINGLE_POINT",
      "space_mode": "SINGLE",
      "sql_template": "SELECT {dimension}, SUM({metric}) as value FROM {table} WHERE {time_filter} {filters} GROUP BY {dimension} ORDER BY value DESC LIMIT {n}",
      "features": ["rank_window", "others_aggregate", "dense_rank_option"],
      "required_tables": ["fact"],
      "optional_features": ["bottom_n", "percentile_threshold"],
      "params_schema": {
        "metric": {"type": "string", "required": true, "description": "排名依据的指标"},
        "dimension": {"type": "string", "required": true, "description": "排名的维度，如：product_name, brand"},
        "n": {"type": "integer", "required": true, "min": 1, "max": 100, "description": "返回的排名数量"},
        "time_point": {"type": "string", "required": true, "description": "统计的时间点或范围"},
        "include_others": {"type": "boolean", "default": true, "description": "是否将非TopN合并为'其他'"}
      },
      "rank_options": ["ROW_NUMBER", "RANK", "DENSE_RANK"],
      "user_prompt": "按指标值进行排名分析，获取TOP N的数据项，快速识别头部数据。",
      "important_notes": ["时间点是必填参数，如：本月、最近7天、2024-03-01到2024-03-31", "N的范围是1-100，支持排名数量调整", "结果按降序排列，自动计算累计占比"],
      "examples": ["本月销售额TOP10的商品", "今年订单量最多的TOP5城市", "最近7天购买次数最多的TOP20用户"]
    },

    "comparison": {
      "id": "comparison",
      "name": "维度对比",
      "description": "维度间对比分析",
      "category": "dimensional",
      "complexity": 2,
      "time_mode": "SINGLE_POINT",
      "space_mode": "PIVOT",
      "sql_template": "SELECT {dimension}, SUM({metric}) as value FROM {table} WHERE {time_filter} {filters} GROUP BY {dimension} ORDER BY value DESC",
      "features": ["pivot_transform", "ratio_calc", "variance_highlight"],
      "required_tables": ["fact"],
      "optional_features": ["heatmap_format", "trend_arrow"],
      "params_schema": {
        "metric": {"type": "string", "required": true, "description": "对比的指标"},
        "dimension": {"type": "string", "required": true, "description": "主要分析维度"},
        "comparison_field": {"type": "string", "required": true, "description": "对比字段，如：channel"},
        "comparison_values": {"type": "array", "required": true, "max_items": 5, "description": "要对比的具体值，如：['线上', '线下']"},
        "time_point": {"type": "string", "required": true, "description": "分析的时间点"}
      },
      "user_prompt": "对比不同维度值之间的指标差异，支持多维度、多值横向对比分析。",
      "important_notes": ["时间点是必填参数，如：本月、上周、2024-03-01", "需要指定对比字段和具体对比值，如：渠道(线上、线下)", "最多支持5个对比值，结果可生成对比图表"],
      "examples": ["对比本月线上和线下两个渠道的销售额", "比较今年产品线A和产品线B的业绩差异", "查看最近3个月不同地区的订单量对比"]
    },

    "funnel": {
      "id": "funnel",
      "name": "漏斗分析",
      "description": "转化漏斗分析",
      "category": "behavioral",
      "complexity": 4,
      "time_mode": "WINDOW",
      "space_mode": "NONE",
      "sql_template": "SELECT event_type, COUNT(DISTINCT user_id) as user_count FROM {table} WHERE {time_filter} GROUP BY event_type ORDER BY user_count DESC",
      "features": ["event_sequence", "window_join", "conversion_calc", "drop_analysis"],
      "required_tables": ["event_table"],
      "optional_features": ["time_between_steps", "segment_breakdown", "path_comparison"],
      "params_schema": {
        "steps": {"type": "array", "required": true, "min_items": 2, "max_items": 8, "items": {"type": "string"}, "description": "漏斗步骤事件列表，如：['注册', '登录', '下单', '支付']"},
        "time_window": {"type": "integer", "default": 7, "unit": "days", "description": "转化窗口期(天)"},
        "strict_order": {"type": "boolean", "default": true, "description": "是否严格要求顺序"},
        "segment_by": {"type": "string", "default": null, "description": "分组维度"}
      },
      "step_time_limit": 168,
      "funnel_types": ["strict", "flexible", "alternative"],
      "user_prompt": "分析用户行为转化漏斗，计算各步骤的转化率和流失率，识别优化点。",
      "important_notes": ["步骤是必填参数，需要指定漏斗的各步骤事件，如：['浏览', '加购', '下单', '支付']", "转化窗口期默认7天，可调整时间范围", "可按用户群组细分漏斗，对比不同群体的转化效果"],
      "examples": ["分析从注册到登录再到下单最后到支付的转化漏斗，时间范围是最近30天", "查看从商品详情页到加入购物车再到下单的转化情况"]
    },

    "retention": {
      "id": "retention",
      "name": "留存分析",
      "description": "用户留存分析",
      "category": "behavioral",
      "complexity": 4,
      "time_mode": "WINDOW",
      "space_mode": "COHORT",
      "sql_template": "SELECT DATE(created_at) as cohort_date, COUNT(DISTINCT user_id) as user_count FROM {table} WHERE {time_filter} GROUP BY DATE(created_at) ORDER BY cohort_date",
      "features": ["cohort_analysis", "survival_calc", "heatmap_output"],
      "required_tables": ["event_table"],
      "optional_features": ["rolling_retention", "unbounded_retention", "revenue_retention"],
      "params_schema": {
        "cohort_grain": {"type": "enum", "options": ["DAY", "WEEK", "MONTH"], "default": "DAY", "description": "群组粒度"},
        "retention_grain": {"type": "enum", "options": ["DAY", "WEEK", "MONTH"], "default": "DAY", "description": "留存粒度"},
        "time_range": {"type": "range", "required": true, "description": "分析的时间范围"},
        "retention_type": {"type": "enum", "options": ["nday", "unbounded", "rolling"], "default": "nday", "description": "留存类型"}
      },
      "retention_windows": [1, 3, 7, 14, 30, 60, 90],
      "user_prompt": "分析用户留存情况，按群组(Cohort)展示不同周期用户的留存率，发现用户流失规律。",
      "important_notes": ["时间范围是必填参数，如：最近90天、从2024-01-01到2024-03-31", "群组粒度可选：按日、按周、按月分组", "常用留存窗口：1日、3日、7日、14日、30日，可发现用户流失的关键时间点"],
      "examples": ["分析最近90天新用户的7日留存率，群组粒度为日", "查看今年不同渠道用户的留存对比情况"]
    },

    "path": {
      "id": "path",
      "name": "路径分析",
      "description": "用户行为路径",
      "category": "behavioral",
      "complexity": 5,
      "time_mode": "WINDOW",
      "space_mode": "SEQUENCE",
      "sql_template": "SELECT event_type, COUNT(*) as frequency FROM {table} WHERE {time_filter} GROUP BY event_type ORDER BY frequency DESC LIMIT 20",
      "features": ["session_extract", "path_compression", "sankey_format", "loop_detection"],
      "required_tables": ["event_table"],
      "optional_features": ["path_matching", "funnel_from_path", "path_duration"],
      "params_schema": {
        "start_event": {"type": "string", "default": null, "description": "路径起始事件"},
        "end_event": {"type": "string", "default": null, "description": "路径结束事件"},
        "session_timeout": {"type": "integer", "default": 30, "unit": "minutes", "description": "会话超时时间"},
        "max_path_length": {"type": "integer", "default": 10, "description": "最大路径长度"},
        "time_range": {"type": "range", "required": true, "description": "分析的时间范围"}
      },
      "user_prompt": "分析用户行为路径，发现常见的用户操作序列，识别关键转化节点和流失点。",
      "important_notes": ["时间范围是必填参数，如：最近30天、从2024-01-01到2024-03-31", "可指定起始事件和结束事件，限定路径分析范围", "会话超时默认30分钟，可调整以适应不同业务场景"],
      "examples": ["分析最近30天用户从首页到下单的常见路径", "查看今年用户在App中的行为轨迹，从登录开始分析"]
    },

    "attribution": {
      "id": "attribution",
      "name": "归因分析",
      "description": "多触点归因",
      "category": "attribution",
      "complexity": 5,
      "time_mode": "WINDOW",
      "space_mode": "MULTI_TOUCH",
      "sql_template": "SELECT source, COUNT(*) as conversions FROM {table} WHERE {time_filter} GROUP BY source ORDER BY conversions DESC",
      "features": ["multi_touch_join", "weight_algorithm", "path_to_conversion"],
      "required_tables": ["touch_table", "conversion_table"],
      "optional_features": ["cross_device", "view_through", "incrementality_test"],
      "params_schema": {
        "model": {"type": "enum", "options": ["first_touch", "last_touch", "linear", "time_decay", "position_based", "data_driven"], "default": "last_touch", "description": "归因模型类型"},
        "lookback_window": {"type": "integer", "default": 30, "unit": "days", "description": "回溯窗口(天)"},
        "time_decay_halflife": {"type": "integer", "default": 7, "unit": "days", "description": "时间衰减半衰期"},
        "time_range": {"type": "range", "required": true, "description": "分析的时间范围"}
      },
      "model_weights": {
        "position_based": {"first": 0.4, "last": 0.4, "middle": 0.2}
      },
      "user_prompt": "分析多触点归因，评估各营销渠道对转化的贡献，支持多种归因模型。",
      "important_notes": ["时间范围是必填参数，如：最近30天、从2024-01-01到2024-03-31", "归因模型可选：首次触点、末次触点、线性、时间衰减、位置相关等", "回溯窗口默认30天，可调整以匹配转化周期"],
      "examples": ["使用末次触点归因模型分析最近30天各营销渠道的转化贡献", "比较不同归因模型下各渠道的效果差异"]
    },

    "anomaly": {
      "id": "anomaly",
      "name": "异常检测",
      "description": "数据异常识别",
      "category": "intelligent",
      "complexity": 3,
      "time_mode": "SERIES",
      "space_mode": "NONE",
