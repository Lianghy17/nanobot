{
  "tables": [
    {
      "table_name": "fact_sales",
      "table_alias": "销售事实表",
      "description": "记录每笔销售订单的详细信息",
      "fields": [
        {
          "field_name": "order_id",
          "field_alias": "订单ID",
          "data_type": "string",
          "is_primary_key": true,
          "description": "订单唯一标识"
        },
        {
          "field_name": "customer_id",
          "field_alias": "客户ID",
          "data_type": "string",
          "is_foreign_key": true,
          "reference_table": "dim_customer",
          "description": "客户唯一标识"
        },
        {
          "field_name": "product_id",
          "field_alias": "产品ID",
          "data_type": "string",
          "is_foreign_key": true,
          "reference_table": "dim_product",
          "description": "产品唯一标识"
        },
        {
          "field_name": "category_id",
          "field_alias": "产品类别ID",
          "data_type": "string",
          "is_foreign_key": true,
          "reference_table": "dim_category",
          "description": "产品类别标识"
        },
        {
          "field_name": "channel_id",
          "field_alias": "渠道ID",
          "data_type": "string",
          "is_foreign_key": true,
          "reference_table": "dim_channel",
          "description": "销售渠道标识"
        },
        {
          "field_name": "region_id",
          "field_alias": "地区ID",
          "data_type": "string",
          "is_foreign_key": true,
          "reference_table": "dim_region",
          "description": "销售地区标识"
        },
        {
          "field_name": "order_date",
          "field_alias": "订单日期",
          "data_type": "date",
          "is_dimension": true,
          "description": "订单创建日期"
        },
        {
          "field_name": "order_time",
          "field_alias": "订单时间",
          "data_type": "datetime",
          "description": "订单创建时间"
        },
        {
          "field_name": "quantity",
          "field_alias": "商品数量",
          "data_type": "integer",
          "is_metric": true,
          "description": "购买商品数量"
        },
        {
          "field_name": "unit_price",
          "field_alias": "单价",
          "data_type": "decimal(10,2)",
          "is_metric": true,
          "description": "商品单价"
        },
        {
          "field_name": "total_amount",
          "field_alias": "订单金额",
          "data_type": "decimal(10,2)",
          "is_metric": true,
          "description": "订单总金额"
        },
        {
          "field_name": "discount_amount",
          "field_alias": "优惠金额",
          "data_type": "decimal(10,2)",
          "description": "订单优惠金额"
        },
        {
          "field_name": "actual_amount",
          "field_alias": "实付金额",
          "data_type": "decimal(10,2)",
          "is_metric": true,
          "description": "实际支付金额"
        },
        {
          "field_name": "cost",
          "field_alias": "成本",
          "data_type": "decimal(10,2)",
          "description": "商品成本"
        },
        {
          "field_name": "status",
          "field_alias": "订单状态",
          "data_type": "string",
          "is_dimension": true,
          "description": "订单状态:pending/confirmed/shipped/completed/cancelled"
        }
      ]
    },
    {
      "table_name": "dim_product",
      "table_alias": "产品维度表",
      "description": "产品基本信息",
      "fields": [
        {
          "field_name": "product_id",
          "field_alias": "产品ID",
          "data_type": "string",
          "is_primary_key": true,
          "description": "产品唯一标识"
        },
        {
          "field_name": "product_name",
          "field_alias": "产品名称",
          "data_type": "string",
          "is_dimension": true,
          "description": "产品名称"
        },
        {
          "field_name": "category_id",
          "field_alias": "产品类别ID",
          "data_type": "string",
          "is_dimension": true,
          "description": "产品类别"
        },
        {
          "field_name": "brand",
          "field_alias": "品牌",
          "data_type": "string",
          "is_dimension": true,
          "description": "产品品牌"
        },
        {
          "field_name": "price",
          "field_alias": "标准价格",
          "data_type": "decimal(10,2)",
          "description": "产品标准价格"
        }
      ]
    },
    {
      "table_name": "dim_category",
      "table_alias": "产品类别维度表",
      "description": "产品类别分类",
      "fields": [
        {
          "field_name": "category_id",
          "field_alias": "类别ID",
          "data_type": "string",
          "is_primary_key": true,
          "description": "类别唯一标识"
        },
        {
          "field_name": "category_name",
          "field_alias": "类别名称",
          "data_type": "string",
          "is_dimension": true,
          "description": "类别名称"
        },
        {
          "field_name": "parent_category_id",
          "field_alias": "父类别ID",
          "data_type": "string",
          "is_dimension": true,
          "description": "父类别ID（用于多级分类）"
        },
        {
          "field_name": "level",
          "field_alias": "级别",
          "data_type": "integer",
          "description": "分类级别"
        }
      ]
    },
    {
      "table_name": "dim_channel",
      "table_alias": "渠道维度表",
      "description": "销售渠道信息",
      "fields": [
        {
          "field_name": "channel_id",
          "field_alias": "渠道ID",
          "data_type": "string",
          "is_primary_key": true,
          "description": "渠道唯一标识"
        },
        {
          "field_name": "channel_name",
          "field_alias": "渠道名称",
          "data_type": "string",
          "is_dimension": true,
          "description": "渠道名称，如：线上/线下"
        },
        {
          "field_name": "channel_type",
          "field_alias": "渠道类型",
          "data_type": "string",
          "is_dimension": true,
          "description": "渠道类型:online/offline/direct/third_party"
        },
        {
          "field_name": "platform",
          "field_alias": "平台",
          "data_type": "string",
          "is_dimension": true,
          "description": "平台信息（针对线上渠道）"
        }
      ]
    },
    {
      "table_name": "dim_region",
      "table_alias": "地区维度表",
      "description": "销售地区信息",
      "fields": [
        {
          "field_name": "region_id",
          "field_alias": "地区ID",
          "data_type": "string",
          "is_primary_key": true,
          "description": "地区唯一标识"
        },
        {
          "field_name": "province",
          "field_alias": "省份",
          "data_type": "string",
          "is_dimension": true,
          "description": "省份"
        },
        {
          "field_name": "city",
          "field_alias": "城市",
          "data_type": "string",
          "is_dimension": true,
          "description": "城市"
        },
        {
          "field_name": "district",
          "field_alias": "区县",
          "data_type": "string",
          "is_dimension": true,
          "description": "区县"
        }
      ]
    },
    {
      "table_name": "dim_customer",
      "table_alias": "客户维度表",
      "description": "客户基本信息",
      "fields": [
        {
          "field_name": "customer_id",
          "field_alias": "客户ID",
          "data_type": "string",
          "is_primary_key": true,
          "description": "客户唯一标识"
        },
        {
          "field_name": "customer_type",
          "field_alias": "客户类型",
          "data_type": "string",
          "is_dimension": true,
          "description": "客户类型:new/returning/vip"
        },
        {
          "field_name": "register_date",
          "field_alias": "注册日期",
          "data_type": "date",
          "description": "客户注册日期"
        },
        {
          "field_name": "first_order_date",
          "field_alias": "首次下单日期",
          "data_type": "date",
          "description": "首次下单日期"
        },
        {
          "field_name": "total_orders",
          "field_alias": "订单总数",
          "data_type": "integer",
          "description": "历史订单总数"
        },
        {
          "field_name": "total_spent",
          "field_alias": "累计消费",
          "data_type": "decimal(10,2)",
          "description": "累计消费金额"
        }
      ]
    },
    {
      "table_name": "dim_date",
      "table_alias": "日期维度表",
      "description": "日期维度信息",
      "fields": [
        {
          "field_name": "date_key",
          "field_alias": "日期键",
          "data_type": "date",
          "is_primary_key": true,
          "description": "日期"
        },
        {
          "field_name": "year",
          "field_alias": "年",
          "data_type": "integer",
          "is_dimension": true,
          "description": "年份"
        },
        {
          "field_name": "month",
          "field_alias": "月",
          "data_type": "integer",
          "is_dimension": true,
          "description": "月份"
        },
        {
          "field_name": "day",
          "field_alias": "日",
          "data_type": "integer",
          "is_dimension": true,
          "description": "日期"
        },
        {
          "field_name": "weekday",
          "field_alias": "星期",
          "data_type": "integer",
          "is_dimension": true,
          "description": "星期几(1-7)"
        },
        {
          "field_name": "week_of_year",
          "field_alias": "周",
          "data_type": "integer",
          "is_dimension": true,
          "description": "一年中的第几周"
        },
        {
          "field_name": "quarter",
          "field_alias": "季度",
          "data_type": "integer",
          "is_dimension": true,
          "description": "季度(1-4)"
        },
        {
          "field_name": "is_holiday",
          "field_alias": "是否节假日",
          "data_type": "boolean",
          "is_dimension": true,
          "description": "是否为节假日"
        }
      ]
    }
  ],
  "relationships": [
    {
      "from_table": "fact_sales",
      "from_field": "customer_id",
      "to_table": "dim_customer",
      "to_field": "customer_id",
      "relationship_type": "many_to_one"
    },
    {
      "from_table": "fact_sales",
      "from_field": "product_id",
      "to_table": "dim_product",
      "to_field": "product_id",
      "relationship_type": "many_to_one"
    },
    {
      "from_table": "fact_sales",
      "from_field": "category_id",
      "to_table": "dim_category",
      "to_field": "category_id",
      "relationship_type": "many_to_one"
    },
    {
      "from_table": "fact_sales",
      "from_field": "channel_id",
      "to_table": "dim_channel",
      "to_field": "channel_id",
      "relationship_type": "many_to_one"
    },
    {
      "from_table": "fact_sales",
      "from_field": "region_id",
      "to_table": "dim_region",
      "to_field": "region_id",
      "relationship_type": "many_to_one"
    },
    {
      "from_table": "fact_sales",
      "from_field": "order_date",
      "to_table": "dim_date",
      "to_field": "date_key",
      "relationship_type": "many_to_one"
    }
  ]
}
