2026-03-19 10:43:05 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "# 创建综合分析图表\nfig, axes = plt.subplots(2, 2, figsize=(14, 10))\nfig.suptitle('销售数据分析报告', fontsize=16, fontweight='bold')\n\n# 1. 各产品类别销售额对比 - 柱状图\nax1 = axes[0, 0]\ncategory_sales = df.groupby('category')['amount'].sum()\ncolors1 = ['#FF6B6B', '#4ECDC4']\nbars1 = ax1.bar(category_sales.index, category_sales.values, color=colors1, edgecolor='black', linewidth=1.2)\nax1.set_title('各产品类别总销售额对比', fontsize=12, fontweight='bold')\nax1.set_ylabel('销售额 (元)', fontsize=10)\nax1.set_xlabel('产品类别', fontsize=10)\n# 添加数值标签\nfor bar in bars1:\n    height = bar.get_height()\n    ax1.text(bar.get_x() + bar.get_width()/2., height,\n             f'{int(height):,}',\n             ha='center', va='bottom', fontsize=10, fontweight='bold')\n\n# 2. 各月份销售额趋势 - 折线图\nax2 = axes[0, 1]\n# 按月份顺序排列\nmonth_order = ['1月', '2月', '3月']\nmonth_sales = df.groupby('month')['amount'].sum().reindex(month_order)\nax2.plot(month_sales.index, month_sales.values, marker='o', linewidth=2.5, \n         markersize=8, color='#3498DB', markerfacecolor='#E74C3C', markeredgecolor='white', markeredgewidth=2)\nax2.set_title('各月份总销售额趋势', fontsize=12, fontweight='bold')\nax2.set_ylabel('销售额 (元)', fontsize=10)\nax2.set_xlabel('月份', fontsize=10)\nax2.grid(True, alpha=0.3, linestyle='--')\n# 添加数值标签\nfor i, (x, y) in enumerate(zip(month_sales.index, month_sales.values)):\n    ax2.text(i, y + 500, f'{int(y):,}', ha='center', fontsize=9, fontweight='bold')\n\n# 3. 产品类别各月销售额 - 分组柱状图\nax3 = axes[1, 0]\npivot_df = df.pivot(index='month', columns='category', values='amount')\npivot_df = pivot_df.reindex(month_order)\nx = np.arange(len(pivot_df.index))\nwidth = 0.35\nbars_a = ax3.bar(x - width/2, pivot_df['A产品'], width, label='A产品', color='#FF6B6B', edgecolor='black')\nbars_b = ax3.bar(x + width/2, pivot_df['B产品'], width, label='B产品', color='#4ECDC4', edgecolor='black')\nax3.set_title('各产品类别月度销售额对比', fontsize=12, fontweight='bold')\nax3.set_ylabel('销售额 (元)', fontsize=10)\nax3.set_xlabel('月份', fontsize=10)\nax3.set_xticks(x)\nax3.set_xticklabels(pivot_df.index)\nax3.legend()\n# 添加数值标签\nfor bars in [bars_a, bars_b]:\n    for bar in bars:\n        height = bar.get_height()\n        ax3.text(bar.get_x() + bar.get_width()/2., height,\n                 f'{int(height):,}',\n                 ha='center', va='bottom', fontsize=8)\n\n# 4. 销售额占比 - 饼图\nax4 = axes[1, 1]\n# 计算各产品占比\nsizes = category_sales.values\ncolors4 = ['#FF6B6B', '#4ECDC4']\nexplode = (0.05, 0)  # 将A产品略微分离\nwedges, texts, autotexts = ax4.pie(sizes, labels=category_sales.index, autopct='%1.1f%%',\n                                     colors=colors4, explode=explode, shadow=True,\n                                     textprops={'fontsize': 11})\nax4.set_title('产品销售额占比', fontsize=12, fontweight='bold')\n# 调整百分比文字样式\nfor autotext in autotexts:\n    autotext.set_color('white')\n    autotext.set_fontweight('bold')\n    autotext.set_fontsize(12)\n\nplt.tight_layout()\nplt.savefig('sales_analysis_charts.png', dpi=150, bbox_inches='tight', facecolor='white')\nplt.show()\nprint(\"\\n图表已保存为: sales_analysis_charts.png\")"}
