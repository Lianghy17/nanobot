63946', '#F1FAEE', '#A8DADC', '#457B9D']\naxes[1, 1].pie(interval_counts.values, labels=interval_counts.index, autopct='%1.1f%%',\n               colors=colors, startangle=90, explode=(0.05, 0, 0, 0.05))\naxes[1, 1].set_title('销售区间占比', fontsize=14, fontweight='bold')\n\nplt.tight_layout()\n\n# 打印统计信息\nprint(\"=\" * 50)\nprint(\"📊 每日销售数据统计\")\nprint(\"=\" * 50)\nprint(f\"数据时间范围: {df['日期'].min().strftime('%Y-%m-%d')} 至 {df['日期'].max().strftime('%Y-%m-%d')}\")\nprint(f\"总销售额: ¥{df['销售额'].sum():,.2f}\")\nprint(f\"平均日销售额: ¥{df['销售额'].mean():,.2f}\")\nprint(f\"最高日销售额: ¥{df['销售额'].max():,.2f}\")\nprint(f\"最低日销售额: ¥{df['销售额'].min():,.2f}\")\nprint(f\"销售额标准差: ¥{df['销售额'].std():,.2f}\")\nprint(\"\\n\" + \"=\" * 50)\n"}
