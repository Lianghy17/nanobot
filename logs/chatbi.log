2026-03-19 11:24:00 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\n# 创建可视化图表\nfig, axes = plt.subplots(2, 2, figsize=(15, 12))\nfig.suptitle('销售数据分析报告', fontsize=16, fontweight='bold')\n\n# 1. 按产品类别的销售额对比\nax1 = axes[0, 0]\ncategory_totals = df.groupby('category')['amount'].sum()\ncolors = ['#FF6B6B', '#4ECDC4']\nax1.pie(category_totals.values, labels=category_totals.index, autopct='%1.1f%%', \n        colors=colors, startangle=90)\nax1.set_title('各产品销售额占比')\n\n# 2. 月份销售趋势\nax2 = axes[0, 1]\nmonth_totals = df.groupby('month')['amount'].sum()\nmonth_order = ['1月', '2月', '3月']\nmonth_totals_ordered = month_totals.reindex(month_order)\nax2.plot(month_totals_ordered.index, month_totals_ordered.values, \n         marker='o', linewidth=2, markersize=8, color='#FF6B6B')\nax2.set_title('月份销售趋势')\nax2.set_xlabel('月份')\nax2.set_ylabel('销售额')\nax2.grid(True, alpha=0.3)\nfor i, v in enumerate(month_totals_ordered.values):\n    ax2.text(i, v + 500, f'{v:,}', ha='center', va='bottom')\n\n# 3. 各产品月份销售对比\nax3 = axes[1, 0]\npivot_data = df.pivot(index='month', columns='category', values='amount')\npivot_data_ordered = pivot_data.reindex(month_order)\nx = range(len(month_order))\nwidth = 0.35\nax3.bar([i - width/2 for i in x], pivot_data_ordered['A产品'], \n        width, label='A产品', color='#FF6B6B')\nax3.bar([i + width/2 for i in x], pivot_data_ordered['B产品'], \n        width, label='B产品', color='#4ECDC4')\nax3.set_title('各产品月份销售对比')\nax3.set_xlabel('月份')\nax3.set_ylabel('销售额')\nax3.set_xticks(x)\nax3.set_xticklabels(month_order)\nax3.legend()\nax3.grid(True, alpha=0.3)\n\n# 4. 增长率对比\nax4 = axes[1, 1]\ngrowth_data = {\n    'A产品': [20.0, 25.0],\n    'B产品': [12.5, 22.2]\n}\nx_pos = range(2)\nax4.bar([i - 0.2 for i in x_pos], growth_data['A产品'], \n        0.4, label='A产品', color='#FF6B6B')\nax4.bar([i + 0.2 for i in x_pos], growth_data['B产品'], \n        0.4, label='B产品', color='#4ECDC4')\nax4.set_title('月增长率对比')\nax4.set_xlabel('增长期间')\nax4.set_ylabel('增长率 (%)')\nax4.set_xticks(x_pos)\nax4.set_xticklabels(['1月-2月', '2月-3月'])\nax4.legend()\nax4.grid(True, alpha=0.3)\n\n# 在柱状图上添加数值标签\nfor i, (a_growth, b_growth) in enumerate(zip(growth_data['A产品'], growth_data['B产品'])):\n    ax4.text(i - 0.2, a_growth + 0.5, f'{a_growth}%', ha='center', va='bottom')\n    ax4.text(i + 0.2, b_growth + 0.5, f'{b_growth}%', ha='center', va='bottom')\n\nplt.tight_layout()\nplt.savefig('sales_analysis_report.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"\\n图表已保存为 'sales_analysis_report.png'\")\n"}
