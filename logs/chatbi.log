2026-03-19 10:11:48 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport numpy as np\n\n# 读取数据\ndf = pd.read_csv('sales_data.csv')\n\n# 设置中文字体\nplt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']\nplt.rcParams['axes.unicode_minus'] = False\n\n# 创建综合图表\nfig, axes = plt.subplots(2, 2, figsize=(15, 12))\nfig.suptitle('销售数据分析报告', fontsize=16, fontweight='bold')\n\n# 1. 各产品月度销售趋势对比\npivot_data = df.pivot(index='month', columns='category', values='amount')\nmonths_order = ['1月', '2月', '3月']\npivot_data = pivot_data.reindex(months_order)\n\nax1 = axes[0, 0]\npivot_data.plot(kind='line', ax=ax1, marker='o', linewidth=2, markersize=8)\nax1.set_title('各产品月度销售趋势', fontsize=12, fontweight='bold')\nax1.set_xlabel('月份')\nax1.set_ylabel('销售额')\nax1.legend(title='产品类别')\nax1.grid(True, alpha=0.3)\n\n# 2. 各产品总销售额对比\nax2 = axes[0, 1]\ncategory_total = df.groupby('category')['amount'].sum()\ncolors = ['#FF6B6B', '#4ECDC4']\nbars = ax2.bar(category_total.index, category_total.values, color=colors, alpha=0.8)\nax2.set_title('各产品总销售额对比', fontsize=12, fontweight='bold')\nax2.set_xlabel('产品类别')\nax2.set_ylabel('总销售额')\n# 添加数值标签\nfor bar in bars:\n    height = bar.get_height()\n    ax2.text(bar.get_x() + bar.get_width()/2., height,\n             f'{int(height):,}', ha='center', va='bottom', fontweight='bold')\n\n# 3. 月度销售额分布\nax3 = axes[1, 0]\nmonthly_total = df.groupby('month')['amount'].sum().reindex(months_order)\nax3.bar(monthly_total.index, monthly_total.values, color='#45B7D1', alpha=0.8)\nax3.set_title('月度总销售额', fontsize=12, fontweight='bold')\nax3.set_xlabel('月份')\nax3.set_ylabel('总销售额')\n# 添加数值标签\nfor i, v in enumerate(monthly_total.values):\n    ax3.text(i, v, f'{int(v):,}', ha='center', va='bottom', fontweight='bold')\n\n# 4. 产品占比饼图\nax4 = axes[1, 1]\nwedges, texts, autotexts = ax4.pie(category_total.values, labels=category_total.index, \n                                   autopct='%1.1f%%', colors=colors, startangle=90)\nax4.set_title('产品销售占比', fontsize=12, fontweight='bold')\n# 设置百分比文字样式\nfor autotext in autotexts:\n    autotext.set_color('white')\n    autotext.set_fontweight('bold')\n\nplt.tight_layout()\nplt.savefig('sales_analysis_report.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"\\n图表已保存为 sales_analysis_report.png\")\n"}
