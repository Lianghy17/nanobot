 label='每日销售额', color='lightgray', alpha=0.7)\naxes[1, 1].plot(df['日期'], df['7日移动平均'], label='7日移动平均', \n                color='#C73E1D', linewidth=2.5)\naxes[1, 1].set_title('销售趋势与移动平均线', fontsize=14, fontweight='bold')\naxes[1, 1].set_xlabel('日期')\naxes[1, 1].set_ylabel('销售额 (元)')\naxes[1, 1].tick_params(axis='x', rotation=45)\naxes[1, 1].legend()\naxes[1, 1].grid(True, alpha=0.3)\n\nplt.tight_layout()\n\n# 打印数据摘要\nprint(\"=\" * 50)\nprint(\"📊 每日销售数据摘要\")\nprint(\"=\" * 50)\nprint(f\"数据时间范围: {df['日期'].min().strftime('%Y-%m-%d')} 至 {df['日期'].max().strftime('%Y-%m-%d')}\")\nprint(f\"总销售额: ¥{df['销售额'].sum():,.2f}\")\nprint(f\"平均日销售额: ¥{df['销售额'].mean():,.2f}\")\nprint(f\"最高日销售额: ¥{df['销售额'].max():,.2f} ({df.loc[df['销售额'].idxmax(), '日期'].strftime('%Y-%m-%d')})\")\nprint(f\"最低日销售额: ¥{df['销售额'].min():,.2f} ({df.loc[df['销售额'].idxmin(), '日期'].strftime('%Y-%m-%d')})\")\nprint(\"=\" * 50)\nprint(\"\\n前10天销售数据:\")\nprint(df.head(10).to_string(index=False))\n"}
