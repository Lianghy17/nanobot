l('Sales Amount (CNY)')\nfor i, v in enumerate(rep_sales.values):\n    axes[1,0].text(v + max(rep_sales.values)*0.01, i, f'¥{v:,.0f}', va='center', fontsize=9)\n\n# 5. 季度销售对比\nquarterly_sales = df.groupby(df['date'].dt.quarter)['total_amount'].sum()\nbars = axes[1,1].bar(quarterly_sales.index, quarterly_sales.values, color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])\naxes[1,1].set_title('Quarterly Sales Comparison', fontweight='bold')\naxes[1,1].set_xlabel('Quarter')\naxes[1,1].set_ylabel('Sales Amount (CNY)')\naxes[1,1].set_xticks([1, 2, 3, 4])\nfor bar in bars:\n    height = bar.get_height()\n    axes[1,1].text(bar.get_x() + bar.get_width()/2., height + max(quarterly_sales.values)*0.01,\n                   f'¥{height:,.0f}', ha='center', va='bottom', fontsize=9)\n\n# 6. 产品数量vs销售额散点图\nproduct_summary = df.groupby('product').agg({\n    'quantity': 'sum',\n    'total_amount': 'sum'\n})\nscatter = axes[1,2].scatter(product_summary['quantity'], product_summary['total_amount'], \n                           s=100, alpha=0.7, c=['red', 'blue', 'green', 'orange', 'purple'])\naxes[1,2].set_title('Product Quantity vs Sales', fontweight='bold')\naxes[1,2].set_xlabel('Total Quantity')\naxes[1,2].set_ylabel('Total Sales Amount (CNY)')\nfor i, product in enumerate(product_summary.index):\n    axes[1,2].annotate(product, (product_summary.iloc[i]['quantity'], product_summary.iloc[i]['total_amount']),\n                      xytext=(5, 5), textcoords='offset points', fontsize=8)\n\nplt.tight_layout()\nplt.savefig('sales_analysis_overview.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"Comprehensive analysis chart saved as 'sales_analysis_overview.png'\")"}
