2026-03-19 09:47:37 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport pandas as pd\n\ndf = pd.read_csv('sales_data.csv')\n\n# 创建图表\nfig, axes = plt.subplots(2, 2, figsize=(10, 8))\nfig.suptitle('Sales Data Analysis', fontsize=14)\n\n# 1. 月度趋势图\nmonthly_sales = df.groupby('month')['amount'].sum().reindex(['1月', '2月', '3月'])\naxes[0,0].plot(monthly_sales.index, monthly_sales.values, marker='o', color='steelblue', linewidth=2)\naxes[0,0].set_title('Monthly Sales Trend')\naxes[0,0].set_ylabel('Sales Amount')\naxes[0,0].grid(True, alpha=0.3)\n\n# 2. 产品占比饼图\nproduct_sales = df.groupby('category')['amount'].sum()\naxes[0,1].pie(product_sales.values, labels=product_sales.index, autopct='%1.1f%%', startangle=90)\naxes[0,1].set_title('Product Sales Share')\n\n# 3. 产品对比柱状图\naxes[1,0].bar(product_sales.index, product_sales.values, color=['coral', 'lightblue'])\naxes[1,0].set_title('Product Comparison')\naxes[1,0].set_ylabel('Sales Amount')\n\n# 4. 趋势对比\npivot_data = df.pivot(index='month', columns='category', values='amount')\npivot_data = pivot_data.reindex(['1月', '2月', '3月'])\nfor i, col in enumerate(pivot_data.columns):\n    color = 'coral' if i == 0 else 'lightblue'\n    axes[1,1].plot(pivot_data.index, pivot_data[col], marker='o', label=col, color=color)\naxes[1,1].set_title('Trend Comparison')\naxes[1,1].legend()\naxes[1,1].grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.savefig('sales_analysis.png', dpi=150, bbox_inches='tight')\nprint(\"Chart saved as: sales_analysis.png\")\n", "timeout": 15}
