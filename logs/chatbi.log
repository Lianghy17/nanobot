2026-03-19 19:20:22 | INFO     | chatbi.core.agent_wrapper:_execute_tool:296 - [工具执行] 参数: {"code": "\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\n\n# 设置中文字体\nplt.rcParams['font.sans-serif'] = ['SimHei', 'Arial Unicode MS']\nplt.rcParams['axes.unicode_minus'] = False\n\n# 生成30天的模拟销售数据\nnp.random.seed(42)\ndays = 30\ndates = [datetime.now() - timedelta(days=days-i) for i in range(days)]\n\n# 模拟销售数据（包含趋势和随机波动）\nbase_sales = 5000\ntrend = np.linspace(0, 1500, days)  # 上升趋势\nnoise = np.random.normal(0, 800, days)  # 随机波动\nweekly_pattern = [1, 0.9, 0.95, 1.05, 1.1, 1.3, 1.2] * 5  # 周末效应\nweekly_pattern = weekly_pattern[:days]\n\nsales = (base_sales + trend + noise) * weekly_pattern\nsales = np.maximum(sales, 1000)  # 确保销售额为正\n\n# 创建DataFrame\ndf = pd.DataFrame({\n    '日期': dates,\n    '销售额': sales.round(2),\n    '订单数': (sales / 150 + np.random.normal(0, 10, days)).round(0).astype(int)\n})\n\n# 创建图表\nfig, axes = plt.subplots(2, 2, figsize=(14, 10))\n\n# 1. 每日销售额趋势图\naxes[0, 0].plot(df['日期'], df['销售额'], marker='o', linewidth=2, markersize=4, color='#2E86AB')\naxes[0, 0].fill_between(df['日期'], df['销售额'], alpha=0.3, color='#2E86AB')\naxes[0, 0].set_title('每日销售额趋势', fontsize=14, fontweight='bold')\naxes[0, 0].set_xlabel('日期')\naxes[0, 0].set_ylabel('销售额 (元)')\naxes[0, 0].tick_params(axis='x', rotation=45)\naxes[0, 0].grid(True, alpha=0.3)\n\n# 2. 销售额柱状图\naxes[0, 1].bar(df['日期'], df['销售额'], color='#A23B72', alpha=0.7)\naxes[0, 1].set_title('每日销售额柱状图', fontsize=14, fontweight='bold')\naxes[0, 1].set_xlabel('日期')\naxes[0, 1].set_ylabel('销售额 (元)')\naxes[0, 1].tick_params(axis='x', rotation=45)\naxes[0, 1].grid(True, alpha=0.3, axis='y')\n\n# 3. 销售额与订单数散点图\naxes[1, 0].scatter(df['订单数'], df['销售额'], c=range(len(df)), cmap='viridis', s=80, alpha=0.7)\naxes[1, 0].set_title('订单数与销售额关系', fontsize=14, fontweight='bold')\naxes[1, 0].set_xlabel('订单数')\naxes[1, 0].set_ylabel('销售额 (元)')\naxes[1, 0].grid(True, alpha=0.3)\n\n# 添加趋势线\nz = np.polyfit(df['订单数'], df['销售额'], 1)\np = np.poly1d(z)\naxes[1, 0].plot(df['订单数'], p(df['订单数']), \"r--\", alpha=0.8, label='趋势线')\naxes[1, 0].legend()\n\n# 4. 周销售额统计\ndf['星期'] = df['日期'].dt.day_name()\nweekday_sales = df.groupby('星期')['销售额'].mean().reindex([\n    'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'\n])\nweekday_names = ['周一', '周二', '周三', '周四', '周五', '周六', '周日']\ncolors = ['#F18F01', '#C73E1D', '#2E86AB', '#A23B72', '#F24236', '#3B1F2B', '#6A994E']\naxes[1, 1].bar(weekday_names, weekday_sales.values, color=colors, alpha=0.8)\naxes[1, 1].set_title('各星期平均销售额', fontsize=14, fontweight='bold')\naxes[1, 1].set_xlabel('星期')\naxes[1, 1].set_ylabel('平均销售额 (元)')\naxes[1, 1].grid(True, alpha=0.3, axis='y')\n\n# 在柱状图上添加数值标签\nfor i, v in enumerate(weekday_sales.values):\n    axes[1, 1].text(i, v + 50, f'{v:.0f}', ha='center', va='bottom', fontsize=10)\n\nplt.tight_layout()\nplt.suptitle('每日销售数据分析报表', fontsize=16, fontweight='bold', y=1.02)\n\n# 打印数据摘要\nprint(\"=\" * 60)\nprint(\"📊 每日销售数据摘要\")\nprint(\"=\" * 60)\nprint(f\"\\n📅 数据时间范围: {df['日期'].min().strftime('%Y-%m-%d')} 至 {df['日期'].max().strftime('%Y-%m-%d')}\")\nprint(f\"\\n💰 销售总额: ¥{df['销售额'].sum():,.2f}\")\nprint(f\"📈 平均日销售额: ¥{df['销售额'].mean():,.2f}\")\nprint(f\"📉 最低日销售额: ¥{df['销售额'].min():,.2f}\")\nprint(f\"📈 最高日销售额: ¥{df['销售额'].max():,.2f}\")\nprint(f\"📦 总订单数: {df['订单数'].sum():,}\")\nprint(f\"📊 平均客单价: ¥{(df['销售额'].sum() / df['订单数'].sum()):,.2f}\")\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"📋 近7天销售数据\")\nprint(\"=\" * 60)\nrecent_data = df.tail(7)[['日期', '销售额', '订单数']].copy()\nrecent_data['日期'] = recent_data['日期'].dt.strftime('%m-%d')\nprint(recent_data.to_string(index=False))\n"}
