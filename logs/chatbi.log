2026-03-19 16:14:16 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "# 创建高级可视化分析\nfig, axes = plt.subplots(2, 2, figsize=(16, 12))\nfig.suptitle('Advanced Sales Analysis', fontsize=16, fontweight='bold')\n\n# 1. 产品-地区热力图\ncross_analysis = df.pivot_table(values='total_amount', index='product', columns='region', aggfunc='sum')\nsns.heatmap(cross_analysis, annot=True, fmt='.0f', cmap='YlOrRd', ax=axes[0,0])\naxes[0,0].set_title('Product-Region Sales Heatmap', fontweight='bold')\naxes[0,0].set_xlabel('Region')\naxes[0,0].set_ylabel('Product')\n\n# 2. 相关性矩阵热力图\ncorrelation_matrix = df[['quantity', 'unit_price', 'total_amount']].corr()\nsns.heatmap(correlation_matrix, annot=True, cmap='coolwarm', center=0, ax=axes[0,1])\naxes[0,1].set_title('Correlation Matrix', fontweight='bold')\n\n# 3. 日度销售趋势时序图\ndaily_sales = df.groupby('date')['total_amount'].sum().reset_index()\naxes[1,0].plot(daily_sales['date'], daily_sales['total_amount'], linewidth=1, alpha=0.7, color='blue')\n# 添加移动平均线\ndaily_sales['ma_30'] = daily_sales['total_amount'].rolling(window=30).mean()\naxes[1,0].plot(daily_sales['date'], daily_sales['ma_30'], linewidth=2, color='red', label='30-day Moving Average')\naxes[1,0].set_title('Daily Sales Trend with Moving Average', fontweight='bold')\naxes[1,0].set_xlabel('Date')\naxes[1,0].set_ylabel('Sales Amount (CNY)')\naxes[1,0].legend()\naxes[1,0].tick_params(axis='x', rotation=45)\n\n# 4. 销售额分布直方图\naxes[1,1].hist(df['total_amount'], bins=50, alpha=0.7, color='green', edgecolor='black')\naxes[1,1].set_title('Sales Amount Distribution', fontweight='bold')\naxes[1,1].set_xlabel('Sales Amount (CNY)')\naxes[1,1].set_ylabel('Frequency')\naxes[1,1].axvline(df['total_amount'].mean(), color='red', linestyle='--', label=f'Mean: ¥{df[\"total_amount\"].mean():.0f}')\naxes[1,1].legend()\n\nplt.tight_layout()\nplt.savefig('advanced_sales_analysis.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"Advanced analysis charts saved as 'advanced_sales_analysis.png'\")"}
