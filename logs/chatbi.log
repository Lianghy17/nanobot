额: ¥{df['销售额'].mean():,.0f}\n最高日销售额: ¥{df['销售额'].max():,.0f}\n最低日销售额: ¥{df['销售额'].min():,.0f}\n销售额标准差: ¥{df['销售额'].std():,.0f}\n\n销售趋势: 上升\n增长率: {((df['销售额'].iloc[-1] - df['销售额'].iloc[0]) / df['销售额'].iloc[0] * 100):.1f}%\n\"\"\"\n\naxes[1, 1].text(0.1, 0.5, stats_text, fontsize=12, verticalalignment='center',\n                bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))\naxes[1, 1].axis('off')\naxes[1, 1].set_title('销售数据统计摘要', fontsize=14, fontweight='bold')\n\nplt.tight_layout()\n\n# 打印数据摘要\nprint(\"=\" * 50)\nprint(\"每日销售数据模拟结果\")\nprint(\"=\" * 50)\nprint(df.head(10).to_string(index=False))\nprint(f\"\\n... 共 {len(df)} 天数据 ...\")\nprint(f\"\\n数据时间范围: {df['日期'].min().strftime('%Y-%m-%d')} 至 {df['日期'].max().strftime('%Y-%m-%d')}\")\nprint(f\"总销售额: ¥{df['销售额'].sum():,.0f}\")\nprint(f\"平均日销售额: ¥{df['销售额'].mean():,.0f}\")\n"}
