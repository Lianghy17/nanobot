ontweight='bold')\nax3.set_ylabel('Sales Amount (CNY)')\nax3.legend()\nfor bars in [bars_a, bars_b]:\n    for bar in bars:\n        height = bar.get_height()\n        ax3.text(bar.get_x() + bar.get_width()/2., height, f'{int(height):,}',\n                 ha='center', va='bottom', fontsize=8)\n\n# 4. 饼图\nax4 = axes[1, 1]\nwedges, texts, autotexts = ax4.pie(category_sales.values, labels=['Product A', 'Product B'], \n                                     autopct='%1.1f%%', colors=colors, explode=(0.05, 0), shadow=True,\n                                     textprops={'fontsize': 11})\nax4.set_title('Sales Distribution', fontsize=11, fontweight='bold')\nfor autotext in autotexts:\n    autotext.set_color('white')\n    autotext.set_fontweight('bold')\n\nplt.tight_layout()\nplt.savefig('sales_analysis_final.png', dpi=150, bbox_inches='tight', facecolor='white')\nprint(\"✅ 图表已保存为: sales_analysis_final.png\")\nprint(\"\\n图表包含:\")\nprint(\"  1. 产品销售额对比 (柱状图)\")\nprint(\"  2. 月份销售趋势 (折线图)\")  \nprint(\"  3. 各产品月度销售对比 (分组柱状图)\")\nprint(\"  4. 销售额占比 (饼图)\")", "timeout": 30}
