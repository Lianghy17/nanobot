um()\ncolors = ['#F18F01', '#C73E1D', '#2E86AB']\nax3.bar(monthly_sales.index, monthly_sales.values, color=colors, alpha=0.8)\nax3.set_title('Monthly Sales Comparison', fontsize=12, fontweight='bold')\nax3.set_xlabel('Month')\nax3.set_ylabel('Sales Amount (CNY)')\nax3.set_xticks(monthly_sales.index)\nfor i, v in enumerate(monthly_sales.values):\n    ax3.text(monthly_sales.index[i], v + 5000, f'{v/10000:.1f}W', ha='center', fontweight='bold')\n\n# 4. 销售额分布直方图\nax4 = axes[1, 1]\nax4.hist(df['销售额'], bins=20, color='#3B1F2B', alpha=0.7, edgecolor='white')\nax4.axvline(df['销售额'].mean(), color='#F24236', linestyle='--', linewidth=2, \n            label=f'Mean: {df[\"销售额\"].mean():.0f}')\nax4.set_title('Sales Distribution Histogram', fontsize=12, fontweight='bold')\nax4.set_xlabel('Sales Amount (CNY)')\nax4.set_ylabel('Frequency')\nax4.legend()\nax4.grid(True, alpha=0.3, axis='y')\n\nplt.tight_layout()\nplt.savefig('daily_sales_trend.png', dpi=150, bbox_inches='tight', facecolor='white')\nplt.show()\n\nprint(\"\\nChart saved as daily_sales_trend.png\")\n"}
