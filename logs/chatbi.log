2026-03-19 12:00:41 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "import pandas as pd\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\n\n# 读取销售数据\ndf = pd.read_csv('sales_data.csv')\n\n# 创建可视化图表\nfig, axes = plt.subplots(2, 2, figsize=(12, 8))\nfig.suptitle('Sales Data Analysis Report', fontsize=14, fontweight='bold')\n\n# 1. 按产品类别的销售额对比\ncategory_sales = df.groupby('category')['amount'].sum()\naxes[0, 0].bar(category_sales.index, category_sales.values, color=['#FF6B6B', '#4ECDC4'])\naxes[0, 0].set_title('Total Sales by Product')\naxes[0, 0].set_ylabel('Sales Amount')\nfor i, v in enumerate(category_sales.values):\n    axes[0, 0].text(i, v + 500, f'{v:,}', ha='center', fontweight='bold')\n\n# 2. 挈月份的销售趋势\nmonth_order = ['1月', '2月', '3月']\nmonth_sales = df.groupby('month')['amount'].sum().reindex(month_order)\naxes[0, 1].plot(range(len(month_sales)), month_sales.values, marker='o', linewidth=2, markersize=8, color='#45B7D1')\naxes[0, 1].set_title('Monthly Sales Trend')\naxes[0, 1].set_ylabel('Sales Amount')\naxes[0, 1].set_xticks(range(len(month_sales)))\naxes[0, 1].set_xticklabels(month_sales.index)\naxes[0, 1].grid(True, alpha=0.3)\nfor i, v in enumerate(month_sales.values):\n    axes[0, 1].text(i, v + 500, f'{v:,}', ha='center', fontweight='bold')\n\n# 3. 产品类别占比饼图\naxes[1, 0].pie(category_sales.values, labels=category_sales.index, autopct='%1.1f%%', \n               colors=['#FF6B6B', '#4ECDC4'], startangle=90)\naxes[1, 0].set_title('Sales Share by Product')\n\n# 4. 各产品各月份销售对比\npivot_df = df.pivot(index='month', columns='category', values='amount')\npivot_df = pivot_df.reindex(month_order)\npivot_df.plot(kind='bar', ax=axes[1, 1], color=['#FF6B6B', '#4ECDC4'])\naxes[1, 1].set_title('Monthly Sales Comparison')\naxes[1, 1].set_ylabel('Sales Amount')\naxes[1, 1].set_xlabel('Month')\naxes[1, 1].legend(title='Product')\naxes[1, 1].tick_params(axis='x', rotation=0)\n\nplt.tight_layout()\nplt.savefig('sales_analysis.png', dpi=150, bbox_inches='tight')\nprint(\"Chart saved as sales_analysis.png\")"}
