ue, alpha=0.3)\n\n# 添加数据标签\nfor i, (a, b) in enumerate(zip(df_pivot['A产品'], df_pivot['B产品'])):\n    axes[1, 0].annotate(f'{a:,}', (i - width/2, a), textcoords=\"offset points\", xytext=(0,5), ha='center')\n    axes[1, 0].annotate(f'{b:,}', (i + width/2, b), textcoords=\"offset points\", xytext=(0,5), ha='center')\n\n# 4. 累计销售额趋势\ndf_cumulative = df.groupby('month')['amount'].sum().cumsum().reset_index()\ndf_cumulative = df_cumulative.set_index('month').reindex(month_order).reset_index()\n\naxes[1, 1].fill_between(df_cumulative['month'], df_cumulative['amount'], alpha=0.6, color='#95E1D3')\naxes[1, 1].plot(df_cumulative['month'], df_cumulative['amount'], marker='s', linewidth=2, markersize=8, color='#2E86AB')\naxes[1, 1].set_title('累计销售额趋势', fontsize=12, fontweight='bold')\naxes[1, 1].set_xlabel('月份')\naxes[1, 1].set_ylabel('累计销售额')\naxes[1, 1].grid(True, alpha=0.3)\nfor i, v in enumerate(df_cumulative['amount']):\n    axes[1, 1].annotate(f'{v:,}', (i, v), textcoords=\"offset points\", xytext=(0,10), ha='center')\n\nplt.tight_layout()\nplt.savefig('sales_analysis_report.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"\\n图表已保存为 'sales_analysis_report.png'\")\n"}
