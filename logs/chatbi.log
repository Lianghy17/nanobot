2026-03-19 10:45:15 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "import matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport pandas as pd\nimport numpy as np\n\n# 读取数据\ndf = pd.read_csv('sales_data.csv')\n\n# 创建图表\nfig, axes = plt.subplots(2, 2, figsize=(12, 9))\nfig.suptitle('Sales Data Analysis Report', fontsize=14, fontweight='bold')\n\n# 1. 产品销售额柱状图\nax1 = axes[0, 0]\ncategory_sales = df.groupby('category')['amount'].sum()\ncolors = ['#FF6B6B', '#4ECDC4']\nbars1 = ax1.bar(category_sales.index, category_sales.values, color=colors, edgecolor='black')\nax1.set_title('Total Sales by Product Category', fontsize=11, fontweight='bold')\nax1.set_ylabel('Sales Amount (CNY)')\nfor bar in bars1:\n    height = bar.get_height()\n    ax1.text(bar.get_x() + bar.get_width()/2., height, f'{int(height):,}',\n             ha='center', va='bottom', fontsize=9, fontweight='bold')\n\n# 2. 月份趋势图\nax2 = axes[0, 1]\nmonth_order = ['1月', '2月', '3月']\nmonth_sales = df.groupby('month')['amount'].sum().reindex(month_order)\nax2.plot(range(len(month_sales)), month_sales.values, marker='o', linewidth=2, \n         markersize=8, color='#3498DB')\nax2.set_xticks(range(len(month_sales)))\nax2.set_xticklabels(month_sales.index)\nax2.set_title('Monthly Sales Trend', fontsize=11, fontweight='bold')\nax2.set_ylabel('Sales Amount (CNY)')\nax2.grid(True, alpha=0.3)\nfor i, y in enumerate(month_sales.values):\n    ax2.text(i, y + 500, f'{int(y):,}', ha='center', fontsize=9)\n\n# 3. 分组柱状图\nax3 = axes[1, 0]\npivot_df = df.pivot(index='month', columns='category', values='amount').reindex(month_order)\nx = np.arange(len(pivot_df.index))\nwidth = 0.35\nax3.bar(x - width/2, pivot_df['A产品'], width, label='Product A', color='#FF6B6B')\nax3.bar(x + width/2, pivot_df['B产品'], width, label='Product B', color='#4ECDC4')\nax3.set_xticks(x)\nax3.set_xticklabels(pivot_df.index)\nax3.set_title('Monthly Sales by Product', fontsize=11, fontweight='bold')\nax3.set_ylabel('Sales Amount (CNY)')\nax3.legend()\n\n# 4. 饼图\nax4 = axes[1, 1]\nax4.pie(category_sales.values, labels=category_sales.index, autopct='%1.1f%%',\n        colors=colors, explode=(0.05, 0), shadow=True)\nax4.set_title('Sales Distribution', fontsize=11, fontweight='bold')\n\nplt.tight_layout()\nplt.savefig('sales_analysis.png', dpi=150, bbox_inches='tight', facecolor='white')\nprint(\"图表已保存为: sales_analysis.png\")\n\n# 显示分析结果\nprint(\"\\n\" + \"=\"*50)\nprint(\"销售数据分析结果\")\nprint(\"=\"*50)\nprint(f\"\\n1. 总销售额: {df['amount'].sum():,} 元\")\nprint(f\"2. A产品销售额: {category_sales['A产品']:,} 元 ({category_sales['A产品']/category_sales.sum()*100:.1f}%)\")\nprint(f\"3. B产品销售额: {category_sales['B产品']:,} 元 ({category_sales['B产品']/category_sales.sum()*100:.1f}%)\")\nprint(f\"4. 销售额最高月份: {month_sales.idxmax()} ({month_sales.max():,} 元)\")\nprint(f\"5. 销售额最低月份: {month_sales.idxmin()} ({month_sales.min():,} 元)\")\nprint(f\"6. 平均月销售额: {month_sales.mean():,.0f} 元\")", "timeout": 30}
