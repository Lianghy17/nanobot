2026-03-19 14:48:53 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\nimport matplotlib.pyplot as plt\nimport numpy as np\nimport base64\nfrom io import BytesIO\n\n# 生成示例数据\nx = np.arange(1, 13)\ny1 = np.array([120, 135, 148, 162, 175, 188, 195, 210, 225, 238, 250, 265])  # 2023年销售额\ny2 = np.array([100, 125, 140, 155, 170, 185, 200, 215, 230, 245, 260, 280])  # 2024年销售额\n\n# 创建图表\nplt.figure(figsize=(12, 6))\nplt.plot(x, y1, marker='o', linewidth=2, label='2023年销售额', color='#3498db')\nplt.plot(x, y2, marker='s', linewidth=2, label='2024年销售额', color='#e74c3c')\n\n# 设置标题和标签\nplt.title('月度销售额趋势对比', fontsize=16, fontweight='bold', pad=20)\nplt.xlabel('月份', fontsize=12)\nplt.ylabel('销售额（万元）', fontsize=12)\nplt.xticks(x, ['1月', '2月', '3月', '4月', '5月', '6月', \n               '7月', '8月', '9月', '10月', '11月', '12月'])\nplt.legend(loc='upper left', fontsize=10)\nplt.grid(True, linestyle='--', alpha=0.7)\n\n# 添加数据标签\nfor i, (v1, v2) in enumerate(zip(y1, y2)):\n    plt.annotate(f'{v1}', (x[i], v1), textcoords=\"offset points\", \n                 xytext=(0,10), ha='center', fontsize=8, color='#3498db')\n    plt.annotate(f'{v2}', (x[i], v2), textcoords=\"offset points\", \n                 xytext=(0,-15), ha='center', fontsize=8, color='#e74c3c')\n\nplt.tight_layout()\n\n# 保存为base64编码的图片\nbuffer = BytesIO()\nplt.savefig(buffer, format='png', dpi=150, bbox_inches='tight')\nbuffer.seek(0)\nimage_base64 = base64.b64encode(buffer.read()).decode('utf-8')\n\nprint(\"图表已生成，Base64编码长度:\", len(image_base64))\nprint(\"前100字符:\", image_base64[:100])\n"}
