olor)\naxes[1, 0].set_title('销售额分布直方图', fontsize=12, fontweight='bold')\naxes[1, 0].set_xlabel('日销售额 (元)')\naxes[1, 0].set_ylabel('频次')\naxes[1, 0].legend()\n\n# 4. 销售量 vs 销售额 散点图\nfor i, (prod, sales_col, qty_col, color) in enumerate(zip(products, sales_cols, quantity_cols, colors)):\n    axes[1, 1].scatter(df[qty_col], df[sales_col], alpha=0.6, label=prod, color=color, s=30)\naxes[1, 1].set_title('销售量 vs 销售额关系', fontsize=12, fontweight='bold')\naxes[1, 1].set_xlabel('销售量 (件)')\naxes[1, 1].set_ylabel('销售额 (元)')\naxes[1, 1].legend()\n\nplt.tight_layout()\nplt.savefig('sales_trend_distribution.png', dpi=150, bbox_inches='tight')\nplt.close()\n\nprint(\"图表2: 销售趋势与分布分析图已生成\")"}
