2026-03-19 09:45:15 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\n# 创建综合分析图表\nfig, axes = plt.subplots(2, 2, figsize=(15, 12))\nfig.suptitle('销售数据综合分析', fontsize=16, fontweight='bold')\n\n# 1. 挈月份的销售趋势图\nmonthly_sales = df.groupby('month')['amount'].sum().reindex(['1月', '2月', '3月'])\naxes[0, 0].plot(monthly_sales.index, monthly_sales.values, marker='o', linewidth=2, markersize=8, color='#2E86AB')\naxes[0, 0].set_title('月度销售趋势', fontsize=12, fontweight='bold')\naxes[0, 0].set_xlabel('月份')\naxes[0, 0].set_ylabel('销售金额')\naxes[0, 0].grid(True, alpha=0.3)\nfor i, v in enumerate(monthly_sales.values):\n    axes[0, 0].text(i, v + 500, f'{v:,}', ha='center', va='bottom', fontweight='bold')\n\n# 2. 按产品类别的销售占比\nproduct_sales = df.groupby('category')['amount'].sum()\ncolors = ['#A23B72', '#F18F01']\naxes[0, 1].pie(product_sales.values, labels=product_sales.index, autopct='%1.1f%%', \n               colors=colors, startangle=90, textprops={'fontweight': 'bold'})\naxes[0, 1].set_title('产品销售占比', fontsize=12, fontweight='bold')\n\n# 3. 产品销售对比柱状图\naxes[1, 0].bar(product_sales.index, product_sales.values, color=colors, alpha=0.8)\naxes[1, 0].set_title('产品销售对比', fontsize=12, fontweight='bold')\naxes[1, 0].set_xlabel('产品类别')\naxes[1, 0].set_ylabel('销售金额')\nfor i, v in enumerate(product_sales.values):\n    axes[1, 0].text(i, v + 500, f'{v:,}', ha='center', va='bottom', fontweight='bold')\n\n# 4. 产品月度销售趋势对比\npivot_data = df.pivot(index='month', columns='category', values='amount')\npivot_data = pivot_data.reindex(['1月', '2月', '3月'])\nfor i, category in enumerate(pivot_data.columns):\n    axes[1, 1].plot(pivot_data.index, pivot_data[category], marker='o', \n                   linewidth=2, markersize=6, label=category, color=colors[i])\naxes[1, 1].set_title('产品月度销售趋势对比', fontsize=12, fontweight='bold')\naxes[1, 1].set_xlabel('月份')\naxes[1, 1].set_ylabel('销售金额')\naxes[1, 1].legend()\naxes[1, 1].grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.savefig('sales_analysis.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"图表已保存为 sales_analysis.png\")\n"}
