ad>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>📊 销售数据分析报告</h1>\n            <p>2024年度销售与利润趋势分析</p>\n        </div>\n        \n        <div class=\"card\">\n            <div class=\"chart-container\">\n                <h2 style=\"margin-bottom: 20px; color: #333;\">折线图展示</h2>\n                <img src=\"data:image/png;base64,''' + image_base64 + '''\" alt=\"Sales Line Chart\">\n            </div>\n        </div>\n        \n        <div class=\"stats-grid\">\n            <div class=\"stat-card sales\">\n                <div class=\"stat-value\">''' + str(sum(sales)) + '''</div>\n                <div class=\"stat-label\">年度总销售额 (万元)</div>\n            </div>\n            <div class=\"stat-card profit\">\n                <div class=\"stat-value\">''' + str(sum(profit)) + '''</div>\n                <div class=\"stat-label\">年度总利润 (万元)</div>\n            </div>\n            <div class=\"stat-card sales\">\n                <div class=\"stat-value\">''' + str(max(sales)) + '''</div>\n                <div class=\"stat-label\">最高月份销售 (万元)</div>\n            </div>\n            <div class=\"stat-card profit\">\n                <div class=\"stat-value\">''' + str(round(sum(profit)/sum(sales)*100, 1)) + '''%</div>\n                <div class=\"stat-label\">年度利润率</div>\n            </div>\n        </div>\n        \n        <div class=\"card\" style=\"margin-top: 30px;\">\n            <h2 style=\"margin-bottom: 20px; color: #333;\">📝 详细数据表格</h2>\n            <table class=\"data-table\">\n                <thead>\n                    <tr>\n                        <th>月份</th>\n                        <th><span class=\"badge badge-sales\">销售额</span></th>\n                        <th><span class=\"badge badge-profit\">利润</span></th>\n                        <th>利润率</th>\n                    </tr>\n                </thead>\n                <tbody>\n'''\n\n# 添加数据行\nfor i, month in enumerate(months):\n    profit_rate = round(profit[i] / sales[i