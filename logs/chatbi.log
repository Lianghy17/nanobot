C73E1D', alpha=0.7, edgecolor='black')\naxes[1, 1].axvline(df['销售额'].mean(), color='blue', linestyle='--', linewidth=2, label=f'平均值: {df[\"销售额\"].mean():.0f}')\naxes[1, 1].set_title('销售额分布', fontsize=14, fontweight='bold')\naxes[1, 1].set_xlabel('销售额（元）')\naxes[1, 1].set_ylabel('天数')\naxes[1, 1].legend()\n\nplt.tight_layout()\n\n# 打印统计信息\nprint(\"=\" * 50)\nprint(\"每日销售数据统计\")\nprint(\"=\" * 50)\nprint(f\"总销售额: ¥{df['销售额'].sum():,.2f}\")\nprint(f\"平均日销售额: ¥{df['销售额'].mean():,.2f}\")\nprint(f\"最高日销售额: ¥{df['销售额'].max():,.2f}\")\nprint(f\"最低日销售额: ¥{df['销售额'].min():,.2f}\")\nprint(f\"总订单数: {df['订单数'].sum():,}\")\nprint(f\"平均日订单数: {df['订单数'].mean():.1f}\")\nprint(\"=\" * 50)\n"}
