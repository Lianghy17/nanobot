2026-03-19 12:04:17 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "import pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\n# 设置中文显示\nplt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']\nplt.rcParams['axes.unicode_minus'] = False\n\n# 读取数据\ndf = pd.read_csv('sales_data.csv')\n\n# 创建图表\nfig, axes = plt.subplots(2, 2, figsize=(14, 10))\nfig.suptitle('销售数据分析报告', fontsize=16, fontweight='bold')\n\n# 1. 按产品类别的销售额对比\nax1 = axes[0, 0]\ncategory_sales = df.groupby('category')['amount'].sum()\ncolors = ['#FF6B6B', '#4ECDC4']\nax1.pie(category_sales.values, labels=category_sales.index, autopct='%1.1f%%', colors=colors, startangle=90)\nax1.set_title('产品类别销售占比', fontsize=12, fontweight='bold')\n\n# 2. 按月份的销售趋势\nax2 = axes[0, 1]\nmonth_sales = df.groupby('month')['amount'].sum()\nmonth_order = ['1月', '2月', '3月']\nmonth_sales = month_sales.reindex(month_order)\nax2.plot(month_sales.index, month_sales.values, marker='o', linewidth=2, markersize=8, color='#FF6B6B')\nax2.set_title('月度销售趋势', fontsize=12, fontweight='bold')\nax2.set_xlabel('月份')\nax2.set_ylabel('销售额')\nax2.grid(True, alpha=0.3)\n\n# 3. 产品类别各月销售对比\nax3 = axes[1, 0]\npivot_df = df.pivot(index='month', columns='category', values='amount')\npivot_df = pivot_df.reindex(month_order)\npivot_df.plot(kind='bar', ax=ax3, color=['#FF6B6B', '#4ECDC4'])\nax3.set_title('产品类别各月销售对比', fontsize=12, fontweight='bold')\nax3.set_xlabel('月份')\nax3.set_ylabel('销售额')\nax3.legend(title='产品类别')\nax3.tick_params(axis='x', rotation=0)\n\n# 4. 各月份销售额分布\nax4 = axes[1, 1]\ndf['month'] = pd.Categorical(df['month'], categories=month_order, ordered=True)\nsns.boxplot(data=df, x='month', y='amount', ax=ax4, palette=['#FF6B6B', '#4ECDC4'])\nax4.set_title('各月份销售额分布', fontsize=12, fontweight='bold')\nax4.set_xlabel('月份')\nax4.set_ylabel('销售额')\n\nplt.tight_layout()\nplt.savefig('sales_analysis.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint(\"\\n✅ 图表已保存为 sales_analysis.png\")"}
