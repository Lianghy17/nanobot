2026-03-18 15:53:00 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\n# 设置中文字体\nplt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']\nplt.rcParams['axes.unicode_minus'] = False\n\n# 创建分析图表\nfig, axes = plt.subplots(2, 2, figsize=(15, 12))\nfig.suptitle('销售数据分析报告', fontsize=16, fontweight='bold')\n\n# 1. 各产品月度销售趋势图\nax1 = axes[0, 0]\nfor category in df['category'].unique():\n    data = df[df['category'] == category]\n    ax1.plot(data['month'], data['amount'], marker='o', linewidth=2, label=category)\nax1.set_title('各产品月度销售趋势', fontsize=12)\nax1.set_xlabel('月份')\nax1.set_ylabel('销售金额')\nax1.legend()\nax1.grid(True, alpha=0.3)\n\n# 2. 产品销售对比柱状图\nax2 = axes[0, 1]\ncategory_sales = df.groupby('category')['amount'].sum()\nbars = ax2.bar(category_sales.index, category_sales.values, color=['#FF6B6B', '#4ECDC4'])\nax2.set_title('产品总销售金额对比', fontsize=12)\nax2.set_xlabel('产品类别')\nax2.set_ylabel('总销售金额')\n# 添加数值标签\nfor bar in bars:\n    height = bar.get_height()\n    ax2.text(bar.get_x() + bar.get_width()/2., height + 500,\n             f'{int(height):,}', ha='center', va='bottom')\n\n# 3. 月度销售分布饼图\nax3 = axes[1, 0]\nmonthly_sales = df.groupby('month')['amount'].sum()\ncolors = ['#FF9999', '#66B2FF', '#99FF99']\nwedges, texts, autotexts = ax3.pie(monthly_sales.values, labels=monthly_sales.index, \n                                   autopct='%1.1f%%', colors=colors, startangle=90)\nax3.set_title('月度销售占比分布', fontsize=12)\n\n# 4. 产品月度销售对比堆叠柱状图\nax4 = axes[1, 1]\npivot_data = df.pivot(index='month', columns='category', values='amount')\npivot_data.plot(kind='bar', ax=ax4, color=['#FF6B6B', '#4ECDC4'])\nax4.set_title('产品月度销售对比', fontsize=12)\nax4.set_xlabel('月份')\nax4.set_ylabel('销售金额')\nax4.legend(title='产品')\nax4.tick_params(axis='x', rotation=0)\n\nplt.tight_layout()\nplt.savefig('sales_analysis.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"图表已保存为 'sales_analysis.png'\")\n"}
