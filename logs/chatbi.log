2026-03-19 14:50:12 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\nimport plotly.graph_objects as go\nfrom plotly.subplots import make_subplots\nimport numpy as np\n\n# 生成示例数据\nmonths = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', \n          'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']\nsales_2023 = [120, 135, 148, 162, 175, 188, 195, 210, 225, 238, 250, 265]\nsales_2024 = [100, 125, 140, 155, 170, 185, 200, 215, 230, 245, 260, 280]\n\n# 创建图表\nfig = go.Figure()\n\n# 添加2023年数据\nfig.add_trace(go.Scatter(\n    x=months,\n    y=sales_2023,\n    mode='lines+markers+text',\n    name='2023 Sales',\n    line=dict(color='#3498db', width=3),\n    marker=dict(size=10, symbol='circle'),\n    text=sales_2023,\n    textposition='top center',\n    hovertemplate='<b>%{x}</b><br>2023 Sales: %{y}M<extra></extra>'\n))\n\n# 添加2024年数据\nfig.add_trace(go.Scatter(\n    x=months,\n    y=sales_2024,\n    mode='lines+markers+text',\n    name='2024 Sales',\n    line=dict(color='#e74c3c', width=3),\n    marker=dict(size=10, symbol='diamond'),\n    text=sales_2024,\n    textposition='bottom center',\n    hovertemplate='<b>%{x}</b><br>2024 Sales: %{y}M<extra></extra>'\n))\n\n# 更新布局\nfig.update_layout(\n    title=dict(\n        text='Monthly Sales Trend Comparison',\n        font=dict(size=24, color='#2c3e50'),\n        x=0.5\n    ),\n    xaxis=dict(\n        title='Month',\n        gridcolor='lightgray',\n        showgrid=True\n    ),\n    yaxis=dict(\n        title='Sales (Million USD)',\n        gridcolor='lightgray',\n        showgrid=True\n    ),\n    legend=dict(\n        orientation='h',\n        yanchor='bottom',\n        y=1.02,\n        xanchor='right',\n        x=1\n    ),\n    plot_bgcolor='white',\n    paper_bgcolor='white',\n    hovermode='x unified',\n    width=1000,\n    height=600\n)\n\n# 保存为HTML文件\nfig.write_html('sales_line_chart.html')\nprint(\"HTML文件已生成: sales_line_chart.html\")\n"}
