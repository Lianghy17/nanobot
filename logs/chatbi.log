2026-03-19 16:05:05 | INFO     | chatbi.core.llm_client:_parse_response:246 -       参数: {"code": "\n# 创建可视化图表\nfig, axes = plt.subplots(2, 2, figsize=(15, 12))\nfig.suptitle('销售数据分析报告', fontsize=16, fontweight='bold')\n\n# 1. 按产品类别的销售额对比\ncategory_sales = df.groupby('category')['amount'].sum()\naxes[0,0].bar(category_sales.index, category_sales.values, color=['#FF6B6B', '#4ECDC4'])\naxes[0,0].set_title('按产品类别销售额对比')\naxes[0,0].set_ylabel('销售额')\nfor i, v in enumerate(category_sales.values):\n    axes[0,0].text(i, v + 500, f'{v:,}', ha='center', fontweight='bold')\n\n# 2. 挈月份趋势分析\nmonth_sales = df.groupby('month')['amount'].sum()\nmonth_order = ['1月', '2月', '3月']\nmonth_sales_ordered = month_sales.reindex(month_order)\naxes[0,1].plot(month_sales_ordered.index, month_sales_ordered.values, \n               marker='o', linewidth=2, markersize=8, color='#45B7D1')\naxes[0,1].set_title('月份销售额趋势')\naxes[0,1].set_ylabel('销售额')\naxes[0,1].grid(True, alpha=0.3)\nfor i, v in enumerate(month_sales_ordered.values):\n    axes[0,1].text(i, v + 300, f'{v:,}', ha='center', fontweight='bold')\n\n# 3. 产品类别月份趋势\npivot_data = df.pivot_table(values='amount', index='month', columns='category', aggfunc='sum')\npivot_data_ordered = pivot_data.reindex(month_order)\npivot_data_ordered.plot(kind='bar', ax=axes[1,0], color=['#FF6B6B', '#4ECDC4'])\naxes[1,0].set_title('各产品月份销售额对比')\naxes[1,0].set_ylabel('销售额')\naxes[1,0].legend(title='产品类别')\naxes[1,0].tick_params(axis='x', rotation=0)\n\n# 4. 销售额占比饼图\naxes[1,1].pie(category_sales.values, labels=category_sales.index, autopct='%1.1f%%', \n              colors=['#FF6B6B', '#4ECDC4'], startangle=90)\naxes[1,1].set_title('产品销售额占比')\n\nplt.tight_layout()\nplt.show()\n\n# 计算增长率\nprint(\"\\n=== 增长分析 ===\")\nmonth_growth = month_sales_ordered.pct_change() * 100\nprint(f\"月份环比增长率:\")\nfor month, growth in month_growth.items():\n    if not pd.isna(growth):\n        print(f\"{month}: {growth:.1f}%\")\n\n# 产品增长分析\nprint(f\"\\n产品增长分析:\")\nfor category in df['category'].unique():\n    cat_data = df[df['category'] == category].sort_values('month')\n    if len(cat_data) > 1:\n        first_month = cat_data.iloc[0]['amount']\n        last_month = cat_data.iloc[-1]['amount']\n        growth = ((last_month - first_month) / first_month) * 100\n        print(f\"{category}: 从{first_month:,} 增长到 {last_month:,} ({growth:+.1f}%)\")\n"}
