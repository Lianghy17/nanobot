].bar(month_names, monthly_sales.values, color='#BC4B51', alpha=0.8)\naxes[1, 0].set_title('月度销售对比', fontsize=14, fontweight='bold')\naxes[1, 0].set_xlabel('月份')\naxes[1, 0].set_ylabel('销售额（元）')\naxes[1, 0].grid(True, alpha=0.3, axis='y')\n\n# 在柱子上添加数值标签\nfor i, v in enumerate(monthly_sales.values):\n    axes[1, 0].text(i, v + 5000, f'{v:,.0f}', ha='center', va='bottom', fontweight='bold')\n\n# 4. 销售分布直方图\naxes[1, 1].hist(df['销售额'], bins=20, color='#8B5A3C', alpha=0.7, edgecolor='black')\naxes[1, 1].set_title('销售额分布', fontsize=14, fontweight='bold')\naxes[1, 1].set_xlabel('销售额（元）')\naxes[1, 1].set_ylabel('天数')\naxes[1, 1].grid(True, alpha=0.3, axis='y')\n\n# 添加均值线\nmean_sales = df['销售额'].mean()\naxes[1, 1].axvline(mean_sales, color='red', linestyle='--', linewidth=2, label=f'平均值: {mean_sales:,.0f}')\naxes[1, 1].legend()\n\nplt.tight_layout()\n\n# 打印数据摘要\nprint(\"=\" * 50)\nprint(\"销售数据摘要\")\nprint(\"=\" * 50)\nprint(f\"数据时间范围: {df['日期'].min().strftime('%Y-%m-%d')} 至 {df['日期'].max().strftime('%Y-%m-%d')}\")\nprint(f\"总销售额: {df['销售额'].sum():,.2f} 元\")\nprint(f\"平均日销售额: {df['销售额'].mean():,.2f} 元\")\nprint(f\"最高日销售额: {df['销售额'].max():,.2f} 元\")\nprint(f\"最低日销售额: {df['销售额'].min():,.2f} 元\")\nprint(f\"销售额标准差: {df['销售额'].std():,.2f} 元\")\nprint(\"=\" * 50)\n"}
