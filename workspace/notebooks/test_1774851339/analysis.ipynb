        "import matplotlib.pyplot as plt",
        "import numpy as np",
        "",
        "x = np.linspace(0, 10, 100)",
        "y = np.sin(x)",
        "",
        "plt.figure(figsize=(8, 4))",
        "plt.plot(x, y)",
        "plt.title('Test Sine Wave')",
        "plt.xlabel('x')",
        "plt.ylabel('sin(x)')",
        "plt.grid(True)",
        "plt.show()",
